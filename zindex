<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Portal City</title>
<style>
body { margin:0; overflow:hidden; background:black; }
#info {
  position:absolute;
  top:10px;
  left:10px;
  color:white;
  font-family:Arial;
}
</style>
</head>
<body>

<div id="info">
Click to lock mouse<br>
WASD = Move<br>
Mouse = Look<br>
Left Click = Blue Portal<br>
Right Click = Orange Portal
</div>

<canvas id="c"></canvas>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

function resize(){
  canvas.width = innerWidth;
  canvas.height = innerHeight;
}
onresize = resize;
resize();

// player
let player = {x:0,z:0,yaw:0};

// portals
let A=null, B=null;

// world
let buildings=[];
for(let i=0;i<60;i++){
  buildings.push({
    x:(Math.random()-0.5)*80,
    z:(Math.random()-0.5)*80,
    size:2+Math.random()*4,
    h:5+Math.random()*15
  });
}

// controls
let keys={};
onkeydown=e=>keys[e.key.toLowerCase()]=true;
onkeyup=e=>keys[e.key.toLowerCase()]=false;

onclick=()=>canvas.requestPointerLock();

onmousemove=e=>{
  if(document.pointerLockElement===canvas){
    player.yaw -= e.movementX*0.002;
  }
};

onmousedown=e=>{
  let dx=Math.sin(player.yaw);
  let dz=Math.cos(player.yaw);

  let hit={
    x:player.x+dx*10,
    z:player.z+dz*10
  };

  if(e.button===0) A=hit;
  if(e.button===2) B=hit;
};

oncontextmenu=e=>e.preventDefault();

// teleport
function teleport(){
  if(!A||!B) return;

  let dA=Math.hypot(player.x-A.x,player.z-A.z);
  let dB=Math.hypot(player.x-B.x,player.z-B.z);

  if(dA<1){
    player.x=B.x;
    player.z=B.z;
  } else if(dB<1){
    player.x=A.x;
    player.z=A.z;
  }
}

// projection
function proj(x,z){
  let dx=x-player.x;
  let dz=z-player.z;

  let cos=Math.cos(player.yaw);
  let sin=Math.sin(player.yaw);

  let rx=dx*cos-dz*sin;
  let rz=dx*sin+dz*cos;

  let s=300/(rz+10);

  return {
    x:canvas.width/2+rx*s,
    y:canvas.height/2,
    s:s,
    d:rz
  };
}

// loop
function loop(){
  requestAnimationFrame(loop);

  let speed=0.1;

  if(keys["w"]){
    player.x+=Math.sin(player.yaw)*speed;
    player.z+=Math.cos(player.yaw)*speed;
  }
  if(keys["s"]){
    player.x-=Math.sin(player.yaw)*speed;
    player.z-=Math.cos(player.yaw)*speed;
  }

  if(keys["a"]) player.yaw+=0.05;
  if(keys["d"]) player.yaw-=0.05;

  teleport();

  ctx.fillStyle="black";
  ctx.fillRect(0,0,canvas.width,canvas.height);

  // draw buildings
  let list=[];
  for(let b of buildings){
    let p=proj(b.x,b.z);
    list.push({b,p});
  }

  list.sort((a,b)=>b.p.d-a.p.d);

  for(let o of list){
    let b=o.b;
    let p=o.p;

    let w=b.size*p.s;
    let h=b.h*p.s;

    ctx.fillStyle="#888";
    ctx.fillRect(p.x-w/2,p.y-h,w,h);
  }

  // portals
  function draw(p,color){
    if(!p) return;
    let pr=proj(p.x,p.z);
    ctx.fillStyle=color;
    ctx.beginPath();
    ctx.arc(pr.x, pr.y, 20*pr.s, 0, Math.PI*2);
    ctx.fill();
  }

  draw(A,"blue");
  draw(B,"orange");
}

loop();
</script>

</body>
</html>
