<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Portal Game</title>
</head>
<body style="margin:0;overflow:hidden;background:black;">

<canvas id="c"></canvas>

<script>
const c = document.getElementById("c");
const ctx = c.getContext("2d");

function resize(){
  c.width = window.innerWidth;
  c.height = window.innerHeight;
}
window.onresize = resize;
resize();

// player
let x=0, z=0, yaw=0;

// portals
let A=null, B=null;

// controls
let keys={};
window.onkeydown=e=>keys[e.key.toLowerCase()]=true;
window.onkeyup=e=>keys[e.key.toLowerCase()]=false;

c.onclick=()=>c.requestPointerLock();

window.onmousemove=e=>{
  if(document.pointerLockElement===c){
    yaw -= e.movementX*0.002;
  }
};

window.onmousedown=e=>{
  let dx=Math.sin(yaw);
  let dz=Math.cos(yaw);

  let hit={x:x+dx*10, z:z+dz*10};

  if(e.button===0) A=hit;
  if(e.button===2) B=hit;
};

window.oncontextmenu=e=>e.preventDefault();

// teleport
function tp(){
  if(!A||!B) return;

  let dA=Math.hypot(x-A.x,z-A.z);
  let dB=Math.hypot(x-B.x,z-B.z);

  if(dA<1){ x=B.x; z=B.z; }
  else if(dB<1){ x=A.x; z=A.z; }
}

// projection
function proj(px,pz){
  let dx=px-x;
  let dz=pz-z;

  let cos=Math.cos(yaw);
  let sin=Math.sin(yaw);

  let rx=dx*cos-dz*sin;
  let rz=dx*sin+dz*cos;

  let s=300/(rz+10);

  return {x:c.width/2+rx*s, y:c.height/2, s:s, d:rz};
}

// buildings
let b=[];
for(let i=0;i<40;i++){
  b.push({
    x:(Math.random()-0.5)*60,
    z:(Math.random()-0.5)*60,
    w:2+Math.random()*4,
    h:5+Math.random()*10
  });
}

// loop
function loop(){
  requestAnimationFrame(loop);

  let speed=0.1;

  if(keys["w"]){ x+=Math.sin(yaw)*speed; z+=Math.cos(yaw)*speed; }
  if(keys["s"]){ x-=Math.sin(yaw)*speed; z-=Math.cos(yaw)*speed; }
  if(keys["a"]) yaw+=0.05;
  if(keys["d"]) yaw-=0.05;

  tp();

  ctx.fillStyle="black";
  ctx.fillRect(0,0,c.width,c.height);

  let list=[];
  for(let o of b){
    let p=proj(o.x,o.z);
    list.push({o,p});
  }

  list.sort((a,b)=>b.p.d-a.p.d);

  for(let e of list){
    let w=e.o.w*e.p.s;
    let h=e.o.h*e.p.s;

    ctx.fillStyle="#888";
    ctx.fillRect(e.p.x-w/2,e.p.y-h,w,h);
  }

  function draw(p,color){
    if(!p) return;
    let pr=proj(p.x,p.z);
    ctx.fillStyle=color;
    ctx.beginPath();
    ctx.arc(pr.x,pr.y,20*pr.s,0,Math.PI*2);
    ctx.fill();
  }

  draw(A,"blue");
  draw(B,"orange");
}

loop();
</script>

</body>
</html>
